# -----------------------------------------------------------------------------
# 与 clean_broker_gateway/.env.example 对齐：PAI-EAS OpenAI 兼容聊天
# （LLM_API_KEY = EAS 公网调用的 Bearer Token，与 DashScope 灵积 key 不是同一把）
# -----------------------------------------------------------------------------

LLM_MODEL_NAME=qwen3.5-397b-fp8
LLM_BASE_URL=https://1204887147554210.cn-wulanchabu.pai-eas.aliyuncs.com/api/predict/qwen3d5_397b_fp8_yifan/v1
LLM_API_KEY=replace-with-pai-eas-bearer-token
LLM_TEMPERATURE=0.7

# 说明：LLM_MODEL_NAME 若带 ``openai/`` 前缀，caker 会在请求前自动去掉，
# 与 clean_broker_gateway/scripts/customer_sim_20.py 行为一致（PAI-EAS 只认后半段模型 id）。

WORKSPACE_ROOT=/tmp/skills
PG_DSN=postgres://agent:agent@localhost:5432/agent_skills
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=agent-skills-state
CHROMA_PATH=./var/chroma
