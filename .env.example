# 复制为 .env 后本地填写。勿将真实 API Key、账号专属 BASE_URL 提交到 Git。
# 文档：https://help.aliyun.com/zh/model-studio/compatibility-of-openai-with-dashscope

# LLM（OpenAI 兼容：PAI-EAS / 百炼 / 自建网关等）
LLM_MODEL_NAME=your-llm-model-name
LLM_BASE_URL=https://your-llm-gateway.example/v1
LLM_API_KEY=replace-with-your-llm-api-key
LLM_TEMPERATURE=0.7

# MemPalace 向量（OpenAI 兼容 embeddings）
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_BASE_URL=https://your-embedding-gateway.example/v1
EMBEDDING_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_DIMENSIONS=1024

WORKSPACE_ROOT=./var/workspace

# 本地路线（M0–M12）可不配置；M10 用 LangGraph SqliteSaver（var/state.db）
# PG_DSN=postgres://user:password@localhost:5432/your_db
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=your-bucket-name

CHROMA_PATH=./var/chroma

# 上下文压缩（软压缩，保留 system + 当前轮 tool 链）
# 默认按 Qwen3.5-397B（原生 262K，建议 ≥128K 上下文）：131072 × 0.85 ≈ 111K 才触发
MAX_INPUT_TOKENS=131072
COMPACT_RATIO=0.85
# LangGraph 图步数上限（llm ↔ tools 循环；默认 50）
GRAPH_RECURSION_LIMIT=50
# MEMPALACE_AUTO_INJECT=false
# 会话超上下文压缩时，将压缩要点写入 Chroma（需 EMBEDDING_*）；关闭则仅会话内 [CONTEXT]
# MEMPALACE_COMPACT_PERSIST=true
# 侧栏会话标题由 LLM 根据对话内容生成（关闭则保持「新对话」/首条截断）
# SESSION_TITLE_AUTO=true
# 会话观测日志写入 workspace/logs/（Agent 只读；引擎写入）
# SESSION_LOG_ENABLED=true
# SESSION_AGENT_LOG_ENABLED=false
# SESSION_LOG_MAX_BYTES=2097152
# SESSION_LOG_BLOB_THRESHOLD=1024
# SESSION_LLM_PREVIEW_ENABLED=false
# SESSION_LLM_PREVIEW_MAX_CHARS=1500
# STREAM_EMIT_TOOL_STATUS=true

# Caker 源码镜子（GitHub 只读自省；可选 token 提高 API 限额）
# CAKER_MIRROR_ENABLED=true
# CAKER_MIRROR_REPO=ecakeman/caker
# CAKER_MIRROR_REF=main
# CAKER_MIRROR_GITHUB_TOKEN=

# CEER V2 — 沙箱终端（宿主机 Docker，Caker 本体不进容器）
SANDBOX_TERMINAL_ENABLED=true
SANDBOX_DOCKER_BIN=docker
SANDBOX_VENUE_IMAGE=python:3.12-slim
# 国内镜像前缀（仅 venue 壳 docker pull）；留空则直连 Docker Hub
DOCKER_PULL_MIRROR_PREFIX=docker.m.daocloud.io
