# 复制为 .env 后本地填写。勿将真实 API Key、账号专属 BASE_URL 提交到 Git。
# 文档：https://help.aliyun.com/zh/model-studio/compatibility-of-openai-with-dashscope

# LLM（OpenAI 兼容：PAI-EAS / 百炼 / 自建网关等）
LLM_MODEL_NAME=your-llm-model-name
LLM_BASE_URL=https://your-llm-gateway.example/v1
LLM_API_KEY=replace-with-your-llm-api-key
LLM_TEMPERATURE=0.7

# MemPalace 向量（OpenAI 兼容 embeddings）
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_BASE_URL=https://your-embedding-gateway.example/v1
EMBEDDING_API_KEY=replace-with-your-embedding-api-key
EMBEDDING_DIMENSIONS=1024

WORKSPACE_ROOT=./var/workspace

# 本地路线（M0–M12）可不配置；M10 用 LangGraph SqliteSaver（var/state.db）
# PG_DSN=postgres://user:password@localhost:5432/your_db
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=your-bucket-name

CHROMA_PATH=./var/chroma
