# Copy to .env and set real API keys.

PARLANT_HOST=0.0.0.0
PARLANT_PORT=8084
PARLANT_TOOL_SERVICE_PORT=9019
PARLANT_HOME=var/runtime
PARLANT_AGENT_NAME=卷叔
PARLANT_SKIP_STARTUP_EVALUATIONS=1

LLM_MODEL_NAME=openai/qwen3.5-397b-fp8
LLM_BASE_URL=https://1204887147554210.cn-wulanchabu.pai-eas.aliyuncs.com/api/predict/qwen3d5_397b_fp8_yifan/v1
LLM_API_KEY=replace-with-chat-key

EMBEDDING_MODEL_NAME=openai/text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=replace-with-dashscope-key
EMBEDDING_DIMENSIONS=1024

# Raw data input (read-only copy under data/raw/)
RAW_GUIDELINES_PATH=data/raw/guidelines.json
RAW_JOURNEYS_PATH=data/raw/journeys.json

# Generated artifacts root (data_pipeline writes, app reads)
ARTIFACTS_ROOT=artifacts
