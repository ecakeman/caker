# Non-secret defaults. Loaded before .env (setdefault); .env wins.

PARLANT_HOST=0.0.0.0
PARLANT_PORT=8084
PARLANT_TOOL_SERVICE_PORT=9019
PARLANT_HOME=var/runtime
PARLANT_AGENT_NAME=卷叔
PARLANT_SKIP_STARTUP_EVALUATIONS=1
PARLANT_PERFORMANCE_POLICY=null
PARLANT_MAX_ENGINE_ITERATIONS=1
PARLANT_OUTPUT_MODE=block
PARLANT_RESPONSE_MODE=one_shot

LLM_MODEL_NAME=openai/qwen3.5-397b-fp8
LLM_BASE_URL=https://1204887147554210.cn-wulanchabu.pai-eas.aliyuncs.com/api/predict/qwen3d5_397b_fp8_yifan/v1
EMBEDDING_MODEL_NAME=openai/text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_DIMENSIONS=1024

RAW_GUIDELINES_PATH=data/raw/guidelines.json
RAW_JOURNEYS_PATH=data/raw/journeys.json
ARTIFACTS_ROOT=artifacts
VAR_ROOT=var
CUSTOMER_SIM_RUN_ROOT=var/customer_sim

PARLANT_CANDIDATE_PROVIDER=1
MATCHING_TOP_K=5
MATCHING_RRF_K=60
MATCHING_ADAPTIVE_K_MAX=12
MATCHING_QUERY_REWRITE=0
GOVERNANCE_GLOSSARY_BOOTSTRAP_MAX=0
